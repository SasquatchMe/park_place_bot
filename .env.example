BOT_TOKEN=put-your-telegram-bot-token-here
ALLOWED_USER_IDS=298532779

# Email (optional). Email feature is enabled when SMTP_USER and SMTP_PASSWORD
# are both set. For Mail.ru use an "app password" generated at
# https://account.mail.ru/user/2-step-auth/passwords (NOT the account password).
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_USER=your-mail@mail.ru
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Имя Отправителя
DEFAULT_RECIPIENT=office@example.ru
